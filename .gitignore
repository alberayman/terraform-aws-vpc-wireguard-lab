# ---- Terraform state ----
*.tfstate
*.tfstate.*
*.tfstate.backup

# ---- Terraform plan files ----
*.tfplan
*.plan

# ---- Terraform provider lock file ----
# Commit this file to pin provider versions for teams.
# It is excluded here for portability; uncomment to track it:
# !.terraform.lock.hcl
.terraform.lock.hcl

# ---- Terraform working directory ----
.terraform/

# ---- Variable files that may contain secrets ----
*.tfvars
# Keep the example template in version control
!*.tfvars.example

# ---- Terraform override files ----
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---- Local Terraform CLI config (may contain credentials) ----
.terraformrc
terraform.rc

# ---- SSH private keys ----
*.pem
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*

# ---- WireGuard private keys ----
*-private.key
privatekey

# ---- Environment files ----
.env
.env.*
*.env

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride

# ---- Editor directories and files ----
.idea/
.vscode/
*.swp
*.swo
*~
